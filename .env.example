# Copy to .env in project root. Restart Expo after changes.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Phase 2: no Gemini key in the app. After deploying `supabase/functions/coach-chat`,
# set secrets in Supabase Dashboard → Edge Functions → coach-chat → Secrets:
#   GEMINI_API_KEY = <Google AI Studio API key>
# Optional: GEMINI_MODEL (Edge default: gemini-2.5-flash). Prefer stable ids: gemini-2.5-flash,
# gemini-2.5-pro. Older secrets like gemini-1.5-flash-latest are remapped to 2.5 in the function.
#
# Phase 4 — account deletion: deploy `delete-account` (uses built-in SUPABASE_SERVICE_ROLE_KEY).
# Deploy: supabase link --project-ref YOUR_REF && supabase functions deploy coach-chat && supabase functions deploy delete-account
